{
    "manifest_version": 3,
    "name": "Dashflow",
    "version": "2.0",
    "description": "A premium glassmorphism new tab dashboard with wallpapers, shortcuts, to-dos, weather, and focus timer.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "permissions": [
        "storage",
        "unlimitedStorage",
        "notifications"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ]
}
